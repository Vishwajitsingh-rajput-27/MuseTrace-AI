<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mt_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/mt_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:text="@string/tagline"
            android:textColor="@color/mt_text_secondary"
            android:textSize="15sp" />

        <com.vishwajitrajput.musetraceai.core.ui.SfInfoCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20">

            <TextView
                android:id="@+id/aboutBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_16"
                android:textColor="@color/mt_text_secondary"
                android:textSize="14sp" />
        </com.vishwajitrajput.musetraceai.core.ui.SfInfoCard>

        <com.vishwajitrajput.musetraceai.core.ui.SfWarningCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12">

            <TextView
                android:id="@+id/aboutWarningText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_16"
                android:textColor="@color/mt_text_secondary"
                android:textSize="14sp" />
        </com.vishwajitrajput.musetraceai.core.ui.SfWarningCard>

        <com.vishwajitrajput.musetraceai.core.ui.SfButton
            android:id="@+id/releaseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:text="Open latest release" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
