<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mt_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <TextView
            android:id="@+id/overlayStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/mt_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.vishwajitrajput.musetraceai.core.ui.SfCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_16">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Why overlay permission is required"
                    android:textColor="@color/mt_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/overlayExplanation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="Instagram Draw may delete the current drawing if you press Back, Home, switch apps, lock the phone, or leave Draw mode. The floating controller stays above Instagram so you can continue, pause, skip, redraw, or stop layers without returning to MuseTrace AI."
                    android:textColor="@color/mt_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.vishwajitrajput.musetraceai.core.ui.SfCard>

        <com.vishwajitrajput.musetraceai.core.ui.SfWarningCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_12"
                android:text="The overlay does not open Instagram, tap Add Space, choose colors, send messages, or bypass restrictions. User manually opens Instagram Draw and manually selects each color."
                android:textColor="@color/mt_text"
                android:textSize="13sp" />
        </com.vishwajitrajput.musetraceai.core.ui.SfWarningCard>

        <com.vishwajitrajput.musetraceai.core.ui.SfButton
            android:id="@+id/requestOverlayButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:text="Open Android overlay settings" />

        <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
            android:id="@+id/startOverlayButton"
            style="@style/Widget.MuseTrace.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Use drawing session checklist" />

        <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
            android:id="@+id/stopOverlayButton"
            style="@style/Widget.MuseTrace.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Stop overlay" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
