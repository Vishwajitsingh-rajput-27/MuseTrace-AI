<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mt_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <com.vishwajitrajput.musetraceai.core.ui.SketchCanvasView
            android:id="@+id/sketchCanvas"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:background="@drawable/bg_preview" />

        <TextView
            android:id="@+id/projectStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:textColor="@color/mt_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/previewTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:background="@color/mt_background" />

        <com.vishwajitrajput.musetraceai.core.ui.SfButton
            android:id="@+id/layersButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:text="Inspect layers" />

        <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
            android:id="@+id/strokesButton"
            style="@style/Widget.MuseTrace.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Inspect strokes" />

        <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
            android:id="@+id/calibrationButton"
            style="@style/Widget.MuseTrace.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Calibrate draw area" />

        <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
            android:id="@+id/drawingButton"
            style="@style/Widget.MuseTrace.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Start drawing session" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
