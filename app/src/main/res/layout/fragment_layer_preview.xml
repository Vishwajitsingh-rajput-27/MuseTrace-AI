<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mt_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Layer preview"
            android:textColor="@color/mt_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/projectSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:textColor="@color/mt_text_secondary"
            android:textSize="14sp" />

        <com.vishwajitrajput.musetraceai.core.ui.SfCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_12">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Final color preview"
                    android:textColor="@color/mt_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/finalPreview"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="@dimen/space_8"
                    android:adjustViewBounds="true"
                    android:background="@drawable/bg_preview"
                    android:contentDescription="Final quantized color preview"
                    android:scaleType="centerInside" />
            </LinearLayout>
        </com.vishwajitrajput.musetraceai.core.ui.SfCard>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/paletteContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <com.vishwajitrajput.musetraceai.core.ui.SfCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_12">

                <TextView
                    android:id="@+id/layerInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/mt_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/layerBitmapPreview"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginTop="@dimen/space_12"
                    android:adjustViewBounds="true"
                    android:background="@drawable/bg_preview"
                    android:contentDescription="Individual layer bitmap preview"
                    android:scaleType="centerInside" />

                <com.vishwajitrajput.musetraceai.core.ui.SketchCanvasView
                    android:id="@+id/layerCanvas"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="@dimen/space_12"
                    android:background="@drawable/bg_preview" />

                <TextView
                    android:id="@+id/layerWarnings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:textColor="@color/mt_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.vishwajitrajput.musetraceai.core.ui.SfCard>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:orientation="horizontal">

            <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
                android:id="@+id/previousLayerButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                android:text="Previous" />

            <com.vishwajitrajput.musetraceai.core.ui.SfButton
                android:id="@+id/nextLayerButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:layout_weight="1"
                android:text="Next" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:orientation="horizontal">

            <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
                android:id="@+id/moveLayerUpButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                android:text="Move earlier" />

            <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
                android:id="@+id/moveLayerDownButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:layout_weight="1"
                android:text="Move later" />
        </LinearLayout>

        <com.vishwajitrajput.musetraceai.core.ui.SfGhostButton
            android:id="@+id/drawingButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Use this sketch in drawing session" />

        <TextView
            android:id="@+id/reorderStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:textColor="@color/mt_text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/layersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:orientation="vertical" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
